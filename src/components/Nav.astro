---
const currentPath = Astro.url.pathname;
const links = [
  { href: '/', label: 'about', path: '/' },
  { href: '/projects/', label: 'projects', path: '/projects' },
  { href: '/experience/', label: 'experience', path: '/experience' },
];
---

<nav class="nav">
  <div class="container">
    <div class="nav-prompt">
      <span class="prompt">visitor@elmisi.com:~$</span>
      <span class="command"> ls</span>
    </div>
    <div class="nav-links">
      {links.map(link => (
        <a
          href={link.href}
          class:list={['nav-link', { active: currentPath === link.href || currentPath === link.path }]}
        >
          {link.label}/
        </a>
      ))}
    </div>
  </div>
</nav>

<style>
  .nav {
    padding: var(--space-3) 0;
    border-bottom: 1px solid var(--border);
    margin-bottom: var(--space-6);
  }
  .nav-prompt {
    margin-bottom: var(--space-1);
  }
  .nav-links {
    display: flex;
    gap: var(--space-3);
    padding-left: 1.5em;
  }
  .nav-link {
    color: var(--text-secondary);
    transition: color 0.15s;
  }
  .nav-link:hover {
    color: var(--accent-green);
  }
  .nav-link.active {
    color: var(--accent-green);
    font-weight: 700;
  }
  @media (max-width: 640px) {
    .nav-links {
      gap: var(--space-2);
      padding-left: 0;
    }
  }
</style>
