---
interface Props {
  name: string;
  years: number;
  level: number;
}

const { name, years, level } = Astro.props;
const filled = level * 2;
const empty = 20 - filled;
const bar = '\u2588'.repeat(filled) + '\u2591'.repeat(empty);
---

<div class="skill-row">
  <span class="skill-name">{name}</span>
  <span class="skill-bar">{bar}</span>
  <span class="skill-years">{years}y</span>
</div>

<style>
  .skill-row {
    display: flex;
    gap: var(--space-2);
    align-items: baseline;
  }
  .skill-name {
    width: 14ch;
    color: var(--text-primary);
    flex-shrink: 0;
  }
  .skill-bar {
    color: var(--accent-green);
    letter-spacing: -0.5px;
  }
  .skill-years {
    color: var(--text-muted);
    width: 4ch;
    text-align: right;
    flex-shrink: 0;
  }
  @media (max-width: 640px) {
    .skill-name { width: 10ch; }
  }
</style>
